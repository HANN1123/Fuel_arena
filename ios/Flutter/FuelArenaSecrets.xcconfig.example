// Copy this file to ios/Flutter/FuelArenaSecrets.xcconfig and fill real values.
// Keep FuelArenaSecrets.xcconfig out of git.

ADMOB_IOS_APP_ID = ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
GOOGLE_IOS_CLIENT_ID = replace-with-ios-client-id.apps.googleusercontent.com
GOOGLE_SERVER_CLIENT_ID = replace-with-server-client-id.apps.googleusercontent.com
GOOGLE_REVERSED_IOS_CLIENT_ID = com.googleusercontent.apps.replace-with-reversed-ios-client-id

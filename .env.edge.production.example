# Copy this file to .env.edge.production for local preflight only.
# In production, set these values with `supabase secrets set`.
# Never pass this file to Flutter build commands.

GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=replace-with-google-play-service-account-json
APP_STORE_CONNECT_ISSUER_ID=replace-with-app-store-connect-issuer-id
APP_STORE_CONNECT_KEY_ID=replace-with-app-store-connect-key-id
APP_STORE_CONNECT_PRIVATE_KEY=replace-with-app-store-connect-private-key
APP_STORE_BUNDLE_ID=com.fuelarena.fuelArena
APP_STORE_ENV=production
ALLOW_MOCK_PURCHASE_VERIFICATION=false
RANKING_JOB_SECRET=replace-with-strong-random-ranking-job-secret

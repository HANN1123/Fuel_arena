# Copy this file to .env.production before release.
# Flutter client/public values only. Do not put Edge Function secrets here.

APP_ENV=production
SUPABASE_URL=replace-with-production-supabase-url
SUPABASE_ANON_KEY=replace-with-production-anon-key

GOOGLE_WEB_CLIENT_ID=replace-with-google-web-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=replace-with-google-android-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_RELEASE_PACKAGE_NAME=com.fuelarena.fuel_arena
GOOGLE_ANDROID_RELEASE_SHA1=replace-with-google-android-release-sha1
GOOGLE_ANDROID_RELEASE_SHA256=replace-with-google-android-release-sha256
GOOGLE_IOS_CLIENT_ID=replace-with-google-ios-client-id.apps.googleusercontent.com
GOOGLE_SERVER_CLIENT_ID=replace-with-google-server-client-id.apps.googleusercontent.com
GOOGLE_REVERSED_IOS_CLIENT_ID=com.googleusercontent.apps.replace-with-google-ios-client-id

APP_AUTH_REDIRECT_SCHEME=fuelarena
APP_AUTH_REDIRECT_HOST=login-callback

ADMOB_ANDROID_APP_ID=replace-with-admob-android-app-id
ADMOB_IOS_APP_ID=replace-with-admob-ios-app-id
ADMOB_REWARDED_ANDROID_UNIT_ID=replace-with-admob-rewarded-android-unit-id
ADMOB_REWARDED_IOS_UNIT_ID=replace-with-admob-rewarded-ios-unit-id
ADMOB_NATIVE_ANDROID_UNIT_ID=replace-with-admob-native-android-unit-id
ADMOB_NATIVE_IOS_UNIT_ID=replace-with-admob-native-ios-unit-id
ADMOB_INTERSTITIAL_ANDROID_UNIT_ID=replace-with-admob-interstitial-android-unit-id
ADMOB_INTERSTITIAL_IOS_UNIT_ID=replace-with-admob-interstitial-ios-unit-id

IAP_PREMIUM_MONTHLY_ID=fuel_arena_premium_monthly
IAP_PREMIUM_YEARLY_ID=fuel_arena_premium_yearly
IAP_SEASON_PASS_ID=fuel_arena_season_pass
IAP_PREMIUM_BUNDLE_ID=fuel_arena_premium_bundle

KAKAO_MAP_KEY=
GOOGLE_MAPS_API_KEY=

PUBLIC_PRIVACY_POLICY_URL=replace-with-public-privacy-policy-url
PUBLIC_LOCATION_NOTICE_URL=replace-with-public-location-notice-url
PUBLIC_ACCOUNT_DELETION_URL=replace-with-public-account-deletion-url
PUBLIC_TERMS_URL=replace-with-public-terms-url
